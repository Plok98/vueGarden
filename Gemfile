source "https://rubygems.org"

# Stable Jekyll line that works with common local setups.
gem "jekyll", "~> 4.3.3"

# Ruby 3.4+/4.0 no longer ships csv as a default gem.
gem "csv", "~> 3.3"
# Ruby 3.4+/4.0 no longer ships base64 as a default gem.
gem "base64", "~> 0.3"

# Required for Ruby 3+ and harmless on older Ruby.
gem "webrick", "~> 1.8"
